lassName\":\"mb-6 text-sm font-semibold uppercase tracking-[0.35em] text-cyan-400\",\"children\":\"About 3rd-AI\"}]}],[\"$\",\"$L3\",null,{\"delay\":0.1,\"children\":[\"$\",\"h1\",null,{\"className\":\"max-w-4xl text-4xl md:text-6xl font-bold leading-[0.94] tracking-tight text-white xl:text-7xl\",\"children\":[\"Networks grew smarter.\",\" \",[\"$\",\"span\",null,{\"className\":\"text-cyan-400\",\"children\":\"The systems managing them didn't.\"}]]}]}],[\"$\",\"$L3\",null,{\"delay\":0.2,\"children\":[\"$\",\"p\",null,{\"className\":\"mt-10 max-w-2xl text-xl leading-9 text-slate-400\",\"children\":\"3rd-AI was built to close that gap — bringing Ambient Intelligence to connected infrastructure so it can sense, understand, orchestrate, and adapt without waiting for a human to tell it to.\"}]}]]}]]}],[\"$\",\"section\",null,{\"className\":\"relative py-12 md:py-24\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-7xl px-8\",\"children\":[\"$\",\"div\",null,{\"className\":\"grid grid-cols-1 gap-16 lg:grid-cols-2 lg:gap-24\",\"children\":[[\"$\",\"$L3\",null,{\"delay\":0,\"children\":[\"$\",\"div\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-3xl font-semibold tracking-tight text-white\",\"children\":\"Founding Story\"}],[\"$\",\"div\",null,{\"className\":\"mt-8 space-y-6 text-lg leading-8 text-slate-400\",\"children\":[[\"$\",\"p\",null,{\"children\":\"After years at the intersection of telecom operations and software, one contradiction became impossible to ignore. Operators were deploying the most sophisticated connected infrastructure ever built — Wi-Fi 7, 5G, edge compute — while the systems responsible for managing it remained largely unchanged from a previous era. The intelligence layer had been left behind.\"}],[\"$\",\"p\",null,{\"children\":\"3rd-AI was founded on the conviction that this gap can be closed. That connected infrastructure — the access points, the routers, the edge devices already deployed in homes and buildings around the world — carries enough signal to understand its own environment. And that understanding should translate directly into action, quietly and continuously, without human intervention, without cloud dependency, and without changing a single piece of hardware.\"}]]}]]}]}],[\"$\",\"$L3\",null,{\"delay\":0.15,\"children\":[\"$\",\"div\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"div\",\"01\",{\"className\":\"rounded-xl border border-cyan-400/40 bg-[#030508] p-6 transition-all duration-300 hover:border-cyan-400/80\",\"children\":[\"$\",\"div\",null,{\"className\":\"flex items-start gap-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"mt-0.5 text-xs font-bold tracking-widest text-cyan-400/50\",\"children\":\"01\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-semibold text-white\",\"children\":\"Infrastructure should think for itself\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm leading-6 text-slate-400\",\"children\":\"Connected environments generate enough signal to understand their own state. Acting on that signal shouldn't require a human in the loop.\"}]]}]]}]}],[\"$\",\"div\",\"02\",{\"className\":\"rounded-xl border border-cyan-400/40 bg-[#030508] p-6 transition-all duration-300 hover:border-cyan-400/80\",\"children\":[\"$\",\"div\",null,{\"className\":\"flex items-start gap-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"mt-0.5 text-xs font-bold tracking-widest text-cyan-400/50\",\"children\":\"02\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-semibold text-white\",\"children\":\"Privacy is non-negotiable\"}],\"$L4\"]}]]}]}],\"$L5\",\"$L6\"]}]}]]}]}]}],\"$L7\",\"$L8\"]}],\"$L9\"],[\"$La\",\"$Lb\"],\"$Lc\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"fLYScEmPXf2l5D5eWy8SF\"}\n4:[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm leading-6 text-slate-400\",\"children\":\"All inference runs locally on the device. Network traffic data never leaves the device — zero cloud egress, by architecture.\"}]\n5:[\"$\",\"div\",\"03\",{\"className\":\"rounded-xl border border-cyan-400/40 bg-[#030508] p-6 transition-all duration-300 hover:border-cyan-400/80\",\"children\":[\"$\",\"div\",null,{\"className\":\"flex items-start gap-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"mt-0.5 text-xs font-bold tracking-widest text-cyan-400/50\",\"children\":\"03\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-semibold text-white\",\"children\":\"The incumbent model is broken\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm leading-6 text-slate-400\",\"children\":\"Telecom OSS/BSS vendors have locked innovation out of the management layer for decades. 3rd-AI exists to prove there's a better way.\"}]]}]]}]}]\n6:[\"$\",\"div\",\"04\",{\"className\":\"rounded-xl border border-cyan-400/40 bg-[#030508] p-6 transition-all duration-300 hover:border-cyan-400/80\",\"children\":[\"$\",\"div\",null,{\"className\":\"flex items-start gap-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"mt-0.5 text-xs font-bold tracking-widest text-cyan-400/50\",\"children\":\"04\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-semibold text-white\",\"children\":\"Energy efficiency is a first-class outcome\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm leading-6 text-slate-400\",\"children\":\"Autonomous optimization isn't just operationally better — it measurably reduces energy consumption and carbon emissions at fleet scale.\"}]]}]]}]}]\n7:[\"$\",\"section\",null,{\"className\":\"relative py-12 md:py-24\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-7xl px-8\",\"children\":[\"$\",\"$L3\",null,{\"delay\":0,\"children\":[\"$\",\"div\",null,{\"className\":\"rounded-2xl border border-cyan-400/20 bg-cyan-400/5 p-12 text-center\",\"children\":[[\"$\",\"p\",null,{\"className\":\"mb-4 text-sm font-semibold uppercase tracking-[0.35em] text-cyan-400/70\",\"children