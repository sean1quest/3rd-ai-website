e\":\"mt-8 space-y-6 text-lg leading-8 text-slate-400\",\"children\":[[\"$\",\"p\",null,{\"children\":\"After years at the intersection of telecom operations and software, one contradiction became impossible to ignore. Operators were deploying the most sophisticated connected infrastructure ever built — Wi-Fi 7, 5G, edge compute — while the systems responsible for managing it remained largely unchanged from a previous era. The intelligence layer had been left behind.\"}],\"$L6\"]}]]}]}],\"$L7\"]}]}]}],\"$L8\",\"$L9\"]}],\"$La\"],[\"$Lb\",\"$Lc\"],\"$Ld\"]}],{},null,false,null]},null,false,\"$@e\"]},null,false,null],\"$Lf\",false]],\"m\":\"$undefined\",\"G\":[\"$10\",[\"$L11\"]],\"S\":true,\"h\":null,\"s\":\"$undefined\",\"l\":\"$undefined\",\"p\":\"$undefined\",\"d\":\"$undefined\",\"b\":\"fLYScEmPXf2l5D5eWy8SF\"}\n12:I[85437,[\"/_next/static/chunks/1d4h-sglyo8ft.js\",\"/_next/static/chunks/3jupxlga7r_do.js\",\"/_next/static/chunks/3vxl_ykt3m0uw.js\",\"/_next/static/chunks/1zdpv00h2h6hi.js\"],\"Image\"]\n13:I[97367,[\"/_next/static/chunks/1d4h-sglyo8ft.js\",\"/_next/static/chunks/3jupxlga7r_do.js\"],\"OutletBoundary\"]\n14:\"$Sreact.suspense\"\n17:I[97367,[\"/_next/static/chunks/1d4h-sglyo8ft.js\",\"/_next/static/chunks/3jupxlga7r_do.js\"],\"ViewportBoundary\"]\n19:I[97367,[\"/_next/static/chunks/1d4h-sglyo8ft.js\",\"/_next/static/chunks/3jupxlga7r_do.js\"],\"MetadataBoundary\"]\n6:[\"$\",\"p\",null,{\"children\":\"3rd-AI was founded on the conviction that this gap can be closed. That connected infrastructure — the access points, the routers, the edge devices already deployed in homes and buildings around the world — carries enough signal to understand its own environment. And that understanding should translate directly into action, quietly and continuously, without human intervention, without cloud dependency, and without changing a single piece of hardware.\"}]\n7:[\"$\",\"$L5\",null,{\"delay\":0.15,\"children\":[\"$\",\"div\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"div\",\"01\",{\"className\":\"rounded-xl border border-cyan-400/40 bg-[#030508] p-6 transition-all duration-300 hover:border-cyan-400/80\",\"children\":[\"$\",\"div\",null,{\"className\":\"flex items-start gap-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"mt-0.5 text-xs font-bold tracking-widest text-cyan-400/50\",\"children\":\"01\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-semibold text-white\",\"children\":\"Infrastructure should think for itself\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm leading-6 text-slate-400\",\"children\":\"Connected environments generate enough signal to understand their own state. Acting on that signal shouldn't require a human in the loop.\"}]]}]]}]}],[\"$\",\"div\",\"02\",{\"className\":\"rounded-xl border border-cyan-400/40 bg-[#030508] p-6 transition-all duration-300 hover:border-cyan-400/80\",\"children\":[\"$\",\"div\",null,{\"className\":\"flex items-start gap-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"mt-0.5 text-xs font-bold tracking-widest text-cyan-400/50\",\"children\":\"02\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-semibold text-white\",\"children\":\"Privacy is non-negotiable\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm leading-6 text-slate-400\",\"children\":\"All inference runs locally on the device. Network traffic data never leaves the device — zero cloud egress, by architecture.\"}]]}]]}]}],[\"$\",\"div\",\"03\",{\"className\":\"rounded-xl border border-cyan-400/40 bg-[#030508] p-6 transition-all duration-300 hover:border-cyan-400/80\",\"children\":[\"$\",\"div\",null,{\"className\":\"flex items-start gap-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"mt-0.5 text-xs font-bold tracking-widest text-cyan-400/50\",\"children\":\"03\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-semibold text-white\",\"children\":\"The incumbent model is broken\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm leading-6 text-slate-400\",\"children\":\"Telecom OSS/BSS vendors have locked innovation out of the management layer for decades. 3rd-AI exists to prove there's a better way.\"}]]}]]}]}],[\"$\",\"div\",\"04\",{\"className\":\"rounded-xl border border-cyan-400/40 bg-[#030508] p-6 transition-all duration-300 hover:border-cyan-400/80\",\"children\":[\"$\",\"div\",null,{\"className\":\"flex items-start gap-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"mt-0.5 text-xs font-bold tracking-widest text-cyan-400/50\",\"children\":\"04\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-semibold text-white\",\"children\":\"Energy efficiency is a first-class outcome\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm leading-6 text-slate-400\",\"children\":\"Autonomous optimization isn't just operationally better — it measurably reduces energy consumption and carbon emissions at fleet scale.\"}]]}]]}]}]]}]}]\n8:[\"$\",\"section\",null,{\"className\":\"relative py-12 md:py-24\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-7xl px-8\",\"children\":[\"$\",\"$L5\",null,{\"delay\":0,\"children\":[\"$\",\"div\",null,{\"className\":\"rounded-2xl border border-cyan-400/20 bg-cyan-400/5 p-12 text-center\",\"children\":[[\"$\",\"p\",null,{\"className\":\"mb-4 text-sm font-semibold uppercase tracking-[0.35em] text-cyan-400/70\",\"children\":\"Our Mission\"}],[\"$\",\"p\",null,{\"className\":\"mx-auto max-w-3xl text-2xl font-semibold leading-snug text-white lg:text-3xl\",\"children\":[\"To bring Ambient Intelligence to connected environments — enabling infrastructure to sense, understand, orchestrate, and adapt\",\" \",[\"$\",\"span\",null,{\"className\":\"text-cyan-400\",\"children\":\"autonomously.\"}]]}]]}]}]}]}]\n9:[\"$\",\"section\",null,{\"className\":\"py-12 md:py-24\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-7xl px-8 text-center\",\"children\":[\"$\",\"$L5\",null,{\