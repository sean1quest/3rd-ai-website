{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/,_N_T_/index"},"segmentPaths":["/_tree","/_full","/__PAGE__","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"geist_a71539c9-module__T19VSG__variable geist_mono_8d43a2aa-module__8Li5zG__variable h-full antialiased\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.0r6juujl39pe6.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.0wgildi0cnwt9.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" as=\"image\" imageSrcSet=\"/_next/image?url=%2Flogo.png&amp;w=256&amp;q=75 1x, /_next/image?url=%2Flogo.png&amp;w=384&amp;q=75 2x\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/3_20n-gs9xnuu.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/1guoti84v2fh3.js\"/><script src=\"/_next/static/chunks/12ng9y1xmtxdd.js\" async=\"\"></script><script src=\"/_next/static/chunks/3ddgzxuxu2x44.js\" async=\"\"></script><script src=\"/_next/static/chunks/3peubv2924kx4.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-3dtu1c8uv8of3.js\" async=\"\"></script><script src=\"/_next/static/chunks/1d4h-sglyo8ft.js\" async=\"\"></script><script src=\"/_next/static/chunks/3jupxlga7r_do.js\" async=\"\"></script><script src=\"/_next/static/chunks/3vxl_ykt3m0uw.js\" async=\"\"></script><script src=\"/_next/static/chunks/1rf5pg4k7p-e2.js\" async=\"\"></script><script src=\"/_next/static/chunks/1zdpv00h2h6hi.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>Create Next App</title><meta name=\"description\" content=\"Generated by create next app\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body class=\"min-h-full flex flex-col\"><div hidden=\"\"><!--$--><!--/$--></div><header class=\"fixed inset-x-0 top-0 z-50 border-b border-white/5 bg-[#05070A]/70 backdrop-blur-xl\"><div class=\"mx-auto flex h-20 max-w-7xl items-center justify-between px-6 md:h-28 md:px-8\"><a href=\"/\" class=\"flex items-center md:self-end md:pb-4\"><img alt=\"3rd-AI\" width=\"140\" height=\"36\" decoding=\"async\" data-nimg=\"1\" style=\"color:transparent;width:clamp(140px, 14vw, 170px);height:auto\" srcSet=\"/_next/image?url=%2Flogo.png&amp;w=256&amp;q=75 1x, /_next/image?url=%2Flogo.png&amp;w=384&amp;q=75 2x\" src=\"/_next/image?url=%2Flogo.png&amp;w=384&amp;q=75\"/></a><nav class=\"hidden items-center gap-12 text-sm font-medium text-slate-400 md:flex\"><a href=\"/#architecture\" class=\"transition-colors duration-300 hover:text-white\">Architecture</a><a href=\"/#platform\" class=\"transition-colors duration-300 hover:text-white\">Platform</a><a href=\"/#validation\" class=\"transition-colors duration-300 hover:text-white\">Validation</a><a href=\"/#contact\" class=\"transition-colors duration-300 hover:text-white\">Contact</a><a href=\"/about\" class=\"transition-colors duration-300 hover:text-white\">About</a></nav><a href=\"/#contact\" class=\"hidden rounded-full border border-cyan-400/60 px-5 py-2.5 text-sm font-medium text-cyan-300 transition-all duration-300 hover:border-cyan-300 hover:bg-cyan-400 hover:text-black md:block\">Technical Briefing</a><button class=\"flex h-10 w-10 flex-col items-center justify-center gap-1.5 rounded-lg md:hidden\" aria-label=\"Toggle menu\"><span class=\"block h-0.5 w-6 bg-white transition-all duration-300 \"></span><span class=\"block h-0.5 w-6 bg-white transition-all duration-300 \"></span><span class=\"block h-0.5 w-6 bg-white transition-all duration-300 \"></span></button></div></header><div class=\"fixed inset-x-0 top-20 z-40 border-b border-white/5 bg-[#05070A]/95 backdrop-blur-xl transition-all duration-300 md:hidden\n          opacity-0 -translate-y-2 pointer-events-none\"><nav class=\"flex flex-col px-6 py-6 gap-1\"><a href=\"/#architecture\" class=\"rounded-lg px-4 py-3 text-base font-medium text-slate-300 transition-colors hover:bg-white/5 hover:text-white\">Architecture</a><a href=\"/#platform\" class=\"rounded-lg px-4 py-3 text-base font-medium text-slate-300 transition-colors hover:bg-white/5 hover:text-white\">Platform</a><a href=\"/#validation\" class=\"rounded-lg px-4 py-3 text-base font-medium text-slate-300 transition-colors hover:bg-white/5 hover:text-white\">Validation</a><a href=\"/#contact\" class=\"rounded-lg px-4 py-3 text-base font-medium text-slate-300 transition-colors hover:bg-white/5 hover:text-white\">Contact</a><a href=\"/about\" class=\"rounded-lg px-4 py-3 text-base font-medium text-slate-300 transition-colors hover:bg-white/5 hover:text-white\">About</a><a href=\"/#contact\" class=\"mt-4 rounded-full border border-cyan-400/60 px-5 py-3 text-center text-sm font-medium text-cyan-300 transition-all hover:bg-cyan-400 hover:text-black\">Technical Briefing</a></nav></div><main><section class=\"relative overflow-hidden bg-black pt-32 pb-24 md:pt-44 md:pb-36\"><div class=\"absolute inset-0\"><video autoPlay=\"\" loop=\"\" muted=\"\" playsInline=\"\" class=\"h-full w-full object-cover\"><source src=\"/videos/hero-ambient-wave-16x9.mp4\" type=\"video/mp4\"/></video><div class=\"absolute inset-0 bg-gradient-to-r from-black/90 via-black/60 to-black/20\"></div><div class=\"absolute inset-0 bg-gradient-to-b from-black/40 via-transparent to-black/50\"></div></div><div class=\"relative mx-auto max-w-7xl px-8\"><div class=\"max-w-2xl\"><div style=\"opacity:0;transform:translateY(24px)\"><p class=\"mb-8 text-sm font-semibold uppercase tracking-[0.1em] md:tracking-[0.35em] leading-relaxed text-cyan-400 md:text-base\"><span class=\"block\">AMBIENT INTELLIGENCE</span><span class=\"block\">FOR CONNECTED ENVIRONMENTS</span></p></div><div style=\"opacity:0;transform:translateY(24px)\"><h1 class=\"text-5xl md:text-6xl xl:text-7xl font-bold leading-[0.94] tracking-tight text-white\">Infrastructure<br/>that <span class=\"text-cyan-400\">understands.</span></h1></div><div style=\"opacity:0;transform:translateY(24px)\"><p class=\"mt-8 max-w-2xl text-base md:text-xl leading-8 md:leading-9 text-slate-300\">3rd-AI transforms connected infrastructure into intelligent systems that continuously perceive, make context-aware decisions, and act autonomously — without changing the underlying hardware.</p></div><div style=\"opacity:0;transform:translateY(24px)\"><div class=\"mt-10 grid grid-cols-2 gap-6 sm:flex sm:flex-row sm:gap-10\"><div><div class=\"flex items-center gap-2 font-semibold text-cyan-400\"><span>Quietly</span><svg class=\"h-5 w-5 text-cyan-400/70\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"></path></svg></div><div class=\"mt-2 text-sm text-slate-400\">Always sensing.</div></div><div><div class=\"flex items-center gap-2 font-semibold text-cyan-400\"><span>Continuously</span><svg class=\"h-5 w-5 text-cyan-400/70\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><polyline points=\"17 1 21 5 17 9\"></polyline><path d=\"M3 11V9a4 4 0 0 1 4-4h14\"></path><polyline points=\"7 23 3 19 7 15\"></polyline><path d=\"M21 13v2a4 4 0 0 1-4 4H3\"></path></svg></div><div class=\"mt-2 text-sm text-slate-400\">Always adapting.</div></div><div><div class=\"flex items-center gap-2 font-semibold text-cyan-400\"><span>Autonomously</span><svg class=\"h-5 w-5 text-cyan-400/70\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><rect x=\"4\" y=\"4\" width=\"16\" height=\"16\" rx=\"2\"></rect><rect x=\"9\" y=\"9\" width=\"6\" height=\"6\"></rect><line x1=\"9\" y1=\"1\" x2=\"9\" y2=\"4\"></line><line x1=\"15\" y1=\"1\" x2=\"15\" y2=\"4\"></line><line x1=\"9\" y1=\"20\" x2=\"9\" y2=\"23\"></line><line x1=\"15\" y1=\"20\" x2=\"15\" y2=\"23\"></line><line x1=\"20\" y1=\"9\" x2=\"23\" y2=\"9\"></line><line x1=\"20\" y1=\"14\" x2=\"23\" y2=\"14\"></line><line x1=\"1\" y1=\"9\" x2=\"4\" y2=\"9\"></line><line x1=\"1\" y1=\"14\" x2=\"4\" y2=\"14\"></line></svg></div><div class=\"mt-2 text-sm text-slate-400\">Always optimizing.</div></div><div><div class=\"flex items-center gap-2 font-semibold text-cyan-400\"><span>Containerised</span><svg class=\"h-5 w-5 text-cyan-400/70\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z\"></path><polyline points=\"3.27 6.96 12 12.01 20.73 6.96\"></polyline><line x1=\"12\" y1=\"22.08\" x2=\"12\" y2=\"12\"></line></svg></div><div class=\"mt-2 text-sm text-slate-400\">Zero Hardware Changes.</div></div></div></div><div style=\"opacity:0;transform:translateY(24px)\"><div class=\"mt-14 flex flex-wrap items-center gap-4\"><a href=\"#platform\" class=\"whitespace-nowrap rounded-full bg-cyan-400 px-7 py-3.5 text-base font-semibold text-black transition-all duration-300 hover:scale-105\">Explore the Platform</a><a href=\"#contact\" class=\"hidden sm:block whitespace-nowrap rounded-full border border-white/15 px-7 py-3.5 text-base text-white transition-all duration-300 hover:border-cyan-400 hover:text-cyan-400\">Request a Technical Briefing</a></div></div></div></div></section><section id=\"architecture\" class=\"relative overflow-hidden bg-black py-16 md:py-32\"><div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(0,217,255,0.05),transparent_65%)]\"></div><div class=\"absolute inset-x-0 -bottom-16 h-56 overflow-hidden\"><img alt=\"\" aria-hidden=\"true\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover opacity-50\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fimages%2Fplatform-banner.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2Fplatform-banner.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2Fplatform-banner.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2Fplatform-banner.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2Fplatform-banner.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2Fplatform-banner.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2Fplatform-banner.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2Fplatform-banner.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2Fplatform-banner.png&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-x-0 top-0 h-16 bg-gradient-to-b from-black to-transparent\"></div></div><div class=\"relative mx-auto max-w-7xl px-8\"><div class=\"mx-auto mb-10 md:mb-20 max-w-3xl text-center\" style=\"opacity:0;transform:translateY(24px)\"><p class=\"mb-3 text-sm font-semibold uppercase tracking-[0.35em] text-cyan-400 md:text-base\">Ambient Intelligence Architecture</p><h2 class=\"text-3xl md:text-5xl font-semibold tracking-tight text-white\">From Awareness to Autonomous Action</h2><p class=\"mt-8 text-lg leading-8 text-slate-400\">A layered system that turns raw environmental signals into autonomous, real-time action — deployed as a container on your existing infrastructure.</p></div><div style=\"opacity:0;transform:translateY(24px)\"><div class=\"flex flex-col gap-4 lg:flex-row lg:items-stretch lg:gap-0\"><div class=\"flex flex-1 items-stretch\"><div class=\"relative flex flex-1 flex-col rounded-2xl border border-cyan-400/40 bg-[#030508] p-6 transition-all duration-300 hover:-translate-y-1 hover:border-cyan-400/80 hover:shadow-[0_0_40px_-10px_rgba(34,211,238,0.4)]\"><span class=\"mb-4 text-sm font-bold tracking-widest text-cyan-400\">01</span><h3 class=\"text-lg font-semibold leading-snug text-cyan-400\">Connected Environment</h3><p class=\"mt-2 text-sm leading-relaxed text-cyan-400/60\">People · Activity · Devices · Infrastructure</p><div class=\"my-4 h-px w-full bg-cyan-400/20\"></div><p class=\"text-base leading-7 text-slate-400\">The physical environment continuously generates signals — device presence, traffic patterns, usage rhythms — that 3rd-AI listens to.</p></div><div class=\"hidden lg:flex w-8 flex-shrink-0 items-center justify-center\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" aria-hidden=\"true\"><path d=\"M4 10h12M12 5l5 5-5 5\" stroke=\"rgba(34,211,238,0.4)\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg></div></div><div class=\"flex flex-1 items-stretch\"><div class=\"relative flex flex-1 flex-col rounded-2xl border border-cyan-400/40 bg-[#030508] p-6 transition-all duration-300 hover:-translate-y-1 hover:border-cyan-400/80 hover:shadow-[0_0_40px_-10px_rgba(34,211,238,0.4)]\"><span class=\"mb-4 text-sm font-bold tracking-widest text-cyan-400\">02</span><h3 class=\"text-lg font-semibold leading-snug text-cyan-400\">Container Runtime</h3><p class=\"mt-2 text-sm leading-relaxed text-cyan-400/60\">OCI-Compliant · Zero Hardware Changes or Integration</p><div class=\"my-4 h-px w-full bg-cyan-400/20\"></div><p class=\"text-base leading-7 text-slate-400\">3rd-AI runs as a container on your existing infrastructure. No hardware modifications. No forklift upgrades. Deploys via standard container tooling.</p></div><div class=\"hidden lg:flex w-8 flex-shrink-0 items-center justify-center\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" aria-hidden=\"true\"><path d=\"M4 10h12M12 5l5 5-5 5\" stroke=\"rgba(34,211,238,0.4)\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg></div></div><div class=\"flex flex-1 items-stretch\"><div class=\"relative flex flex-1 flex-col rounded-2xl border border-cyan-400/40 bg-[#030508] p-6 transition-all duration-300 hover:-translate-y-1 hover:border-cyan-400/80 hover:shadow-[0_0_40px_-10px_rgba(34,211,238,0.4)]\"><span class=\"mb-4 text-sm font-bold tracking-widest text-cyan-400\">03</span><h3 class=\"text-lg font-semibold leading-snug text-cyan-400\">Continuous Telemetry</h3><p class=\"mt-2 text-sm leading-relaxed text-cyan-400/60\">Real-Time Environmental Awareness</p><div class=\"my-4 h-px w-full bg-cyan-400/20\"></div><p class=\"text-base leading-7 text-slate-400\">Raw signals are normalized, filtered, and streamed into the intelligence engine — every band, every device, every minute.</p></div><div class=\"hidden lg:flex w-8 flex-shrink-0 items-center justify-center\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" aria-hidden=\"true\"><path d=\"M4 10h12M12 5l5 5-5 5\" stroke=\"rgba(34,211,238,0.4)\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg></div></div><div class=\"flex flex-1 items-stretch\"><div class=\"relative flex flex-1 flex-col rounded-2xl border border-cyan-400/40 bg-[#030508] p-6 transition-all duration-300 hover:-translate-y-1 hover:border-cyan-400/80 hover:shadow-[0_0_40px_-10px_rgba(34,211,238,0.4)]\"><span class=\"mb-4 text-sm font-bold tracking-widest text-cyan-400\">04</span><h3 class=\"text-lg font-semibold leading-snug text-cyan-400\">Ambient Intelligence Engine</h3><p class=\"mt-2 text-sm leading-relaxed text-cyan-400/60\">Contextual Understanding · Pattern Learning · Decision Intelligence</p><div class=\"my-4 h-px w-full bg-cyan-400/20\"></div><p class=\"text-base leading-7 text-slate-400\">The core of the platform. Behavioral patterns are learned, context is understood, and autonomous decisions are made — entirely on-device.</p><div class=\"mt-4 inline-flex w-fit items-center gap-1.5 rounded-full border border-cyan-400/30 bg-cyan-400/10 px-3 py-1\"><div class=\"h-1.5 w-1.5 animate-pulse rounded-full bg-cyan-400\"></div><span class=\"text-xs font-medium text-cyan-400\">On-Device · Zero Egress</span></div></div><div class=\"hidden lg:flex w-8 flex-shrink-0 items-center justify-center\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" aria-hidden=\"true\"><path d=\"M4 10h12M12 5l5 5-5 5\" stroke=\"rgba(34,211,238,0.4)\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg></div></div><div class=\"flex flex-1 items-stretch\"><div class=\"relative flex flex-1 flex-col rounded-2xl border border-cyan-400/40 bg-[#030508] p-6 transition-all duration-300 hover:-translate-y-1 hover:border-cyan-400/80 hover:shadow-[0_0_40px_-10px_rgba(34,211,238,0.4)]\"><span class=\"mb-4 text-sm font-bold tracking-widest text-cyan-400\">05</span><h3 class=\"text-lg font-semibold leading-snug text-cyan-400\">Autonomous Orchestration</h3><p class=\"mt-2 text-sm leading-relaxed text-cyan-400/60\">Policy &amp; Action Coordination</p><div class=\"my-4 h-px w-full bg-cyan-400/20\"></div><p class=\"text-base leading-7 text-slate-400\">Decisions are translated into precise, targeted actions across the infrastructure — executed autonomously without human intervention.</p></div></div></div></div><div style=\"opacity:0;transform:translateY(24px)\"><div class=\"mt-12 flex flex-col gap-6 px-2 py-5 lg:flex-row lg:items-center lg:justify-between lg:gap-8\"><p class=\"text-base leading-7 text-slate-400\"><span class=\"text-lg font-semibold text-cyan-400\">Container-native deployment.</span> <!-- -->3rd-AI runs as an OCI-compliant container on your existing infrastructure — no hardware modifications, no vendor lock-in, no forklift upgrades required.</p><div class=\"flex flex-wrap gap-4 text-xs font-medium lg:flex-shrink-0 lg:gap-6\"><span class=\"text-lg font-semibold text-cyan-400/70\">OCI-Compliant</span><span class=\"text-slate-600\">·</span><span class=\"text-lg font-semibold text-cyan-400/70\">Open Standards</span><span class=\"text-slate-600\">·</span><span class=\"text-lg font-semibold text-cyan-400/70\">Zero Hardware Changes or Integration</span></div></div></div></div></section><section id=\"platform\" class=\"relative overflow-hidden bg-[#030508] py-16 md:py-32\"><div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(0,217,255,0.05),transparent_60%)]\"></div><div class=\"relative mx-auto max-w-7xl px-8\"><div class=\"mx-auto mb-10 md:mb-20 max-w-4xl text-center\" style=\"opacity:0;transform:translateY(24px)\"><p class=\"mb-4 text-sm font-semibold uppercase tracking-[0.35em] text-cyan-400 md:text-base\">Platform</p><h2 class=\"text-3xl md:text-5xl font-semibold leading-tight tracking-tight text-white\">Wi-Fi Power Optimization<br/><span class=\"text-cyan-400\">Driven by Behavior.</span></h2><p class=\"mx-auto mt-8 max-w-3xl text-lg leading-8 text-slate-400\">Most access points run all radios at full power, around the clock — regardless of whether anyone is using them. 3rd-AI learns real household usage patterns and autonomously powers down idle radios during confirmed quiet windows. No schedules. No rules. No cloud.</p></div><div style=\"opacity:0;transform:translateY(24px)\"><div class=\"grid gap-px overflow-hidden rounded-3xl border border-cyan-400/40 bg-cyan-400/20 md:grid-cols-2\"><div class=\"group bg-[#030508] p-10 transition-all duration-300 hover:bg-white/[0.04] hover:shadow-[inset_0_0_50px_-12px_rgba(34,211,238,0.4)]\"><span class=\"mb-4 block text-sm font-bold tracking-widest text-cyan-400\">01</span><h3 class=\"text-xl font-semibold text-cyan-400\">Behavioral Traffic Analysis</h3><p class=\"mt-4 text-base leading-7 text-slate-400\">3rd-AI ingests per-band telemetry from the access point — every client, every minute. A KMeans clustering algorithm identifies IDLE vs ACTIVE traffic boundaries, self-calibrating thresholds per radio interface based on real household usage patterns.</p><div class=\"mt-8 h-px w-16 bg-cyan-400\"></div></div><div class=\"group bg-[#030508] p-10 transition-all duration-300 hover:bg-white/[0.04] hover:shadow-[inset_0_0_50px_-12px_rgba(34,211,238,0.4)]\"><span class=\"mb-4 block text-sm font-bold tracking-widest text-cyan-400\">02</span><h3 class=\"text-xl font-semibold text-cyan-400\">Coverage Fidelity Gating</h3><p class=\"mt-4 text-base leading-7 text-slate-400\">Before acting, the platform validates telemetry coverage per hourly window. Hours below 65% fidelity are flagged as SPARSE SIGNAL — the agent abstains rather than misread a data gap as genuine inactivity. Conservative by design.</p><div class=\"mt-8 h-px w-16 bg-cyan-400\"></div></div><div class=\"group bg-[#030508] p-10 transition-all duration-300 hover:bg-white/[0.04] hover:shadow-[inset_0_0_50px_-12px_rgba(34,211,238,0.4)]\"><span class=\"mb-4 block text-sm font-bold tracking-widest text-cyan-400\">03</span><h3 class=\"text-xl font-semibold text-cyan-400\">On-Device Inference</h3><p class=\"mt-4 text-base leading-7 text-slate-400\">The Ambient Intelligence Engine runs entirely inside the container — no cloud round-trip. It forecasts the next 24-hour optimization window using a structured behavioral context table, confirming a sleep schedule only when all radio interfaces agree.</p><div class=\"mt-8 h-px w-16 bg-cyan-400\"></div></div><div class=\"group bg-[#030508] p-10 transition-all duration-300 hover:bg-white/[0.04] hover:shadow-[inset_0_0_50px_-12px_rgba(34,211,238,0.4)]\"><span class=\"mb-4 block text-sm font-bold tracking-widest text-cyan-400\">04</span><h3 class=\"text-xl font-semibold text-cyan-400\">Autonomous Radio Management</h3><p class=\"mt-4 text-base leading-7 text-slate-400\">Once confirmed, the platform delivers action payloads directly to the AP power-control API. High-band radios (5 GHz, 6 GHz) enter sleep state. Clients are steered to the 2.4 GHz anchor. Full audit trail written to local storage.</p><div class=\"mt-8 h-px w-16 bg-cyan-400\"></div></div></div></div><div style=\"opacity:0;transform:translateY(24px)\"><div class=\"mt-8 px-2 py-6\"><p class=\"mb-5 text-xs font-semibold uppercase tracking-[0.3em] text-cyan-400/70\">Technical Specifications</p><div class=\"grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-6\"><div><p class=\"text-xs font-medium text-slate-500 uppercase tracking-wider\">Deployment</p><p class=\"mt-1 text-sm font-medium text-slate-300\">OCI container · zero hardware changes</p></div><div><p class=\"text-xs font-medium text-slate-500 uppercase tracking-wider\">Inference</p><p class=\"mt-1 text-sm font-medium text-slate-300\">On-device · zero cloud egress</p></div><div><p class=\"text-xs font-medium text-slate-500 uppercase tracking-wider\">Telemetry</p><p class=\"mt-1 text-sm font-medium text-slate-300\">Per-band · per-minute · MQTT</p></div><div><p class=\"text-xs font-medium text-slate-500 uppercase tracking-wider\">Threshold</p><p class=\"mt-1 text-sm font-medium text-slate-300\">KMeans adaptive · per radio interface</p></div><div><p class=\"text-xs font-medium text-slate-500 uppercase tracking-wider\">Privacy</p><p class=\"mt-1 text-sm font-medium text-slate-300\">No data leaves the device</p></div><div><p class=\"text-xs font-medium text-slate-500 uppercase tracking-wider\">Standards</p><p class=\"mt-1 text-sm font-medium text-slate-300\">Open · vendor-agnostic</p></div></div></div></div></div></section><section id=\"validation\" class=\"relative overflow-hidden bg-[#04070C] py-12 md:py-32\"><div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(0,217,255,0.05),transparent_65%)]\"></div><div class=\"relative mx-auto max-w-7xl px-8\"><div class=\"mx-auto mb-20 max-w-4xl text-center\" style=\"opacity:0;transform:translateY(24px)\"><p class=\"mb-4 text-sm font-semibold uppercase tracking-[0.35em] text-cyan-400 md:text-base\">Market Validation</p><h2 class=\"text-3xl md:text-5xl font-semibold tracking-tight text-white\">Validated in Real-World Environments</h2><p class=\"mx-auto mt-8 max-w-3xl text-lg leading-8 text-slate-400\">The Ambient Intelligence Platform has been validated through real-world deployment, demonstrating measurable operational value while establishing the foundation for future intelligent applications.</p></div><div class=\"mb-20 px-2\" style=\"opacity:0;transform:translateY(24px)\"><div class=\"mx-auto mb-12 max-w-3xl text-center\"><p class=\"mb-3 text-sm font-semibold uppercase tracking-[0.35em] text-cyan-400\">Measured Results — Wi-Fi Power Optimization</p><h3 class=\"text-2xl font-semibold text-white md:text-3xl\">One example use case with proven results</h3><p class=\"mt-4 text-slate-400\">Learned from real user behavior patterns — without impacting the user experience.</p></div><div class=\"grid grid-cols-1 gap-6 text-center sm:grid-cols-2 md:grid-cols-4\"><div class=\"rounded-2xl border border-cyan-400/20 bg-[#04070C] p-4 transition-all duration-300 hover:border-cyan-400/60 hover:bg-white/[0.04] hover:shadow-[0_0_40px_-10px_rgba(34,211,238,0.5)]\"><div class=\"whitespace-nowrap text-3xl font-bold text-cyan-400 md:text-4xl lg:text-5xl\"><span>0</span><span class=\"text-2xl md:text-3xl\">%</span></div><div class=\"mt-3 text-sm text-slate-400\">Power Reduction</div></div><div class=\"rounded-2xl border border-cyan-400/20 bg-[#04070C] p-4 transition-all duration-300 hover:border-cyan-400/60 hover:bg-white/[0.04] hover:shadow-[0_0_40px_-10px_rgba(34,211,238,0.5)]\"><div class=\"whitespace-nowrap text-3xl font-bold text-cyan-400 md:text-4xl lg:text-5xl\"><span>0</span><span class=\"text-xl md:text-2xl\"> tCO₂e</span></div><div class=\"mt-3 text-sm text-slate-400\">Avoided Annually</div></div><div class=\"rounded-2xl border border-cyan-400/20 bg-[#04070C] p-4 transition-all duration-300 hover:border-cyan-400/60 hover:bg-white/[0.04] hover:shadow-[0_0_40px_-10px_rgba(34,211,238,0.5)]\"><div class=\"whitespace-nowrap text-3xl font-bold text-cyan-400 md:text-4xl lg:text-5xl\"><span>0.0</span><span class=\"text-2xl md:text-3xl\"> GWh</span></div><div class=\"mt-3 text-sm text-slate-400\">Annual Energy Saving*</div></div><div class=\"rounded-2xl border border-cyan-400/20 bg-[#04070C] p-4 transition-all duration-300 hover:border-cyan-400/60 hover:bg-white/[0.04] hover:shadow-[0_0_40px_-10px_rgba(34,211,238,0.5)]\"><div class=\"whitespace-nowrap text-3xl font-bold text-cyan-400 md:text-4xl lg:text-5xl\"><span>$</span><span>0.0</span><span class=\"text-2xl md:text-3xl\">M+</span></div><div class=\"mt-3 text-sm text-slate-400\">Annual Cost Savings*</div></div></div><p class=\"mt-10 text-center text-xs text-slate-500\">*Projected at a deployment scale of 1 million access points.</p></div><div class=\"mb-20\" style=\"opacity:0;transform:translateY(24px)\"><div><div class=\"flex flex-col gap-1 rounded-xl border border-white/8 bg-white/[0.02] p-1 sm:flex-row\"><button class=\"flex-1 rounded-lg px-4 py-2.5 text-sm font-medium transition-all duration-200\n              bg-cyan-400/10 text-cyan-400 border border-cyan-400/30\">Network Traffic Profile</button><button class=\"flex-1 rounded-lg px-4 py-2.5 text-sm font-medium transition-all duration-200\n              text-slate-500 hover:text-slate-300\">Hour Classification</button><button class=\"flex-1 rounded-lg px-4 py-2.5 text-sm font-medium transition-all duration-200\n              text-slate-500 hover:text-slate-300\">Power Consumption</button></div><div class=\"mt-6 px-2\"><p class=\"mb-6 text-xs text-slate-500\">Avg MB/min per hour · 2026-05-08 to 2026-05-12 (UTC+8) · QUIET zone = autonomous sleep window</p><div class=\"min-h-[280px]\"><div class=\"w-full\"><div class=\"recharts-responsive-container\" style=\"width:100%;height:320px;min-width:0\"><div style=\"width:0;overflow-x:visible\"></div></div><div class=\"mt-4 flex items-center gap-6 text-xs text-slate-500\"><div class=\"flex items-center gap-2\"><div class=\"h-3 w-3 rounded-sm\" style=\"background:rgba(34,211,238,0.15)\"></div><span>Quiet zone — autonomous sleep authorized</span></div><div class=\"flex items-center gap-2\"><div class=\"h-3 w-3 rounded-sm\" style=\"background:rgba(239,68,68,0.12)\"></div><span>Busy zone — radios remain active</span></div></div></div></div></div></div></div><div class=\"grid gap-6 md:grid-cols-2\"><div style=\"opacity:0;transform:translateY(24px)\"><div class=\"h-full rounded-2xl border border-cyan-400/40 bg-[#04070C] p-10 transition-all duration-300 hover:-translate-y-1 hover:border-cyan-400/80 hover:shadow-[0_0_40px_-10px_rgba(34,211,238,0.4)]\"><div class=\"mb-6 h-px w-16 bg-cyan-400\"></div><h3 class=\"text-xl font-semibold text-cyan-400\">Real-World Validation</h3><p class=\"mt-4 leading-7 text-slate-400\">Successfully demonstrated on live connected infrastructure, validating the Ambient Intelligence Platform under real-world deployment conditions.</p></div></div><div style=\"opacity:0;transform:translateY(24px)\"><div class=\"h-full rounded-2xl border border-cyan-400/40 bg-[#04070C] p-10 transition-all duration-300 hover:-translate-y-1 hover:border-cyan-400/80 hover:shadow-[0_0_40px_-10px_rgba(34,211,238,0.4)]\"><div class=\"mb-6 h-px w-16 bg-cyan-400\"></div><h3 class=\"text-xl font-semibold text-cyan-400\">Measurable Impact</h3><p class=\"mt-4 leading-7 text-slate-400\">Autonomous optimization learns real usage patterns, identifies quiet periods, and reduces energy consumption — without impacting the user experience.</p></div></div><div style=\"opacity:0;transform:translateY(24px)\"><div class=\"h-full rounded-2xl border border-cyan-400/40 bg-[#04070C] p-10 transition-all duration-300 hover:-translate-y-1 hover:border-cyan-400/80 hover:shadow-[0_0_40px_-10px_rgba(34,211,238,0.4)]\"><div class=\"mb-6 h-px w-16 bg-cyan-400\"></div><h3 class=\"text-xl font-semibold text-cyan-400\">Expandable Platform</h3><p class=\"mt-4 leading-7 text-slate-400\">Designed to grow beyond energy optimization into new intelligent applications — all without changing the underlying platform or infrastructure.</p></div></div><div style=\"opacity:0;transform:translateY(24px)\"><div class=\"h-full rounded-2xl border border-cyan-400/40 bg-[#04070C] p-10 transition-all duration-300 hover:-translate-y-1 hover:border-cyan-400/80 hover:shadow-[0_0_40px_-10px_rgba(34,211,238,0.4)]\"><div class=\"mb-6 h-px w-16 bg-cyan-400\"></div><h3 class=\"text-xl font-semibold text-cyan-400\">Ready for Operator Deployment</h3><p class=\"mt-4 leading-7 text-slate-400\">Built for carrier-grade environments with a scalable, container-native architecture designed for deployment across large infrastructure fleets.</p></div></div></div><div class=\"mx-auto mt-10 md:mt-24 max-w-4xl text-center\" style=\"opacity:0;transform:translateY(24px)\"><p class=\"text-xl leading-9 text-slate-300\">One use case. Proven results. More to come.</p></div></div></section><section id=\"company\" class=\"relative overflow-hidden bg-[#020406] py-16 md:py-36\"><div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(0,217,255,0.08),transparent_60%)]\"></div><canvas class=\"absolute inset-0 h-full w-full\" aria-hidden=\"true\"></canvas><div class=\"relative mx-auto max-w-5xl px-8 text-center\" style=\"opacity:0;transform:translateY(24px)\"><p class=\"mb-6 text-sm font-semibold uppercase tracking-[0.35em] text-cyan-400 md:text-base\">Let&#x27;s Build the Future Together</p><h2 class=\"text-3xl md:text-6xl font-semibold leading-tight tracking-tight text-white\">Infrastructure has connected everything.<br/><span class=\"text-cyan-400\">Now it can finally understand it.</span></h2><p class=\"mx-auto mt-8 max-w-3xl text-lg md:text-xl leading-8 md:leading-9 text-slate-400\">See how Ambient Intelligence turns your infrastructure into a system that thinks for itself.</p><div class=\"mt-10 flex flex-wrap justify-center gap-6\"><a href=\"#contact\" class=\"rounded-full bg-cyan-400 px-10 py-4 text-lg font-semibold text-black transition-all duration-300 hover:scale-105\">Request a Technical Briefing</a></div></div></section><section id=\"contact\" class=\"relative overflow-hidden bg-black py-16 md:py-32\"><div class=\"absolute inset-0 bg-[radial-gradient(circle_at_80%_30%,rgba(0,217,255,0.05),transparent_60%)]\"></div><div class=\"relative mx-auto max-w-7xl px-8\"><div class=\"grid grid-cols-1 gap-16 lg:grid-cols-2 lg:items-start\"><div style=\"opacity:0;transform:translateY(24px)\"><p class=\"mb-4 text-sm font-semibold uppercase tracking-[0.35em] text-cyan-400 md:text-base\">Get In Touch</p><h2 class=\"text-3xl md:text-5xl font-semibold tracking-tight text-white\">Let&#x27;s talk about your infrastructure.</h2><p class=\"mt-8 max-w-xl text-lg leading-8 text-slate-400\">Whether you&#x27;re evaluating the platform, exploring a pilot deployment, or just have questions about how Ambient Intelligence fits your environment — reach out and our team will follow up directly.</p><div class=\"mt-12 space-y-6\"><div><div class=\"text-sm font-semibold text-cyan-400\">Email</div><div class=\"mt-1 text-slate-300\">info@3rd-ai.com</div></div><div><div class=\"text-sm font-semibold text-cyan-400\">LinkedIn</div><a href=\"https://www.linkedin.com/company/3rd-ai-com/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"mt-1 block text-slate-300 transition-colors duration-300 hover:text-cyan-400\">linkedin.com/company/3rd-ai-com</a></div></div></div><div class=\"rounded-3xl border border-white/10 bg-white/[0.03] p-10\" style=\"opacity:0;transform:translateY(24px)\"><form class=\"space-y-6\"><div><label for=\"name\" class=\"mb-2 block text-sm font-medium text-slate-300\">Name</label><input id=\"name\" type=\"text\" required=\"\" class=\"w-full rounded-xl border border-white/10 bg-black/40 px-4 py-3 text-white placeholder:text-slate-600 outline-none transition-colors duration-300 focus:border-cyan-400/60\" placeholder=\"Your name\" name=\"name\"/></div><div><label for=\"email\" class=\"mb-2 block text-sm font-medium text-slate-300\">Email</label><input id=\"email\" type=\"email\" required=\"\" class=\"w-full rounded-xl border border-white/10 bg-black/40 px-4 py-3 text-white placeholder:text-slate-600 outline-none transition-colors duration-300 focus:border-cyan-400/60\" placeholder=\"you@company.com\" name=\"email\"/></div><div><label for=\"message\" class=\"mb-2 block text-sm font-medium text-slate-300\">Message</label><textarea id=\"message\" name=\"message\" required=\"\" rows=\"5\" class=\"w-full resize-none rounded-xl border border-white/10 bg-black/40 px-4 py-3 text-white placeholder:text-slate-600 outline-none transition-colors duration-300 focus:border-cyan-400/60\" placeholder=\"Tell us about your infrastructure and what you&#x27;re looking to solve.\"></textarea></div><button type=\"submit\" class=\"w-full rounded-full bg-cyan-400 px-8 py-4 text-lg font-semibold text-black transition-all duration-300 hover:scale-[1.02] disabled:cursor-not-allowed disabled:opacity-60\">Send Message</button></form></div></div></div></section></main><footer class=\"border-t border-white/5 bg-[#05070A] py-12\"><div class=\"mx-auto max-w-7xl px-8\"><div class=\"flex flex-col gap-8 md:flex-row md:items-start md:justify-between\"><div><a href=\"/\" class=\"inline-flex items-center self-end\"><img alt=\"3rd-AI\" loading=\"lazy\" width=\"120\" height=\"30\" decoding=\"async\" data-nimg=\"1\" style=\"color:transparent;width:120px;height:auto\" srcSet=\"/_next/image?url=%2Flogo.png&amp;w=128&amp;q=75 1x, /_next/image?url=%2Flogo.png&amp;w=256&amp;q=75 2x\" src=\"/_next/image?url=%2Flogo.png&amp;w=256&amp;q=75\"/></a><p class=\"mt-3 max-w-xs text-sm leading-6 text-slate-500\">Ambient Intelligence for connected environments.</p></div><nav class=\"flex flex-wrap gap-x-10 gap-y-3 text-sm text-slate-500\"><a href=\"/#architecture\" class=\"transition-colors hover:text-slate-300\">Architecture</a><a href=\"/#platform\" class=\"transit