"children\":[[\"$\",\"div\",null,{\"className\":\"absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(0,217,255,0.05),transparent_60%)]\"}],[\"$\",\"div\",null,{\"className\":\"relative mx-auto max-w-7xl px-8\",\"children\":[[\"$\",\"$L5\",null,{\"className\":\"mx-auto mb-10 md:mb-20 max-w-4xl text-center\",\"children\":[[\"$\",\"p\",null,{\"className\":\"mb-4 text-sm font-semibold uppercase tracking-[0.35em] text-cyan-400 md:text-base\",\"children\":\"Platform\"}],[\"$\",\"h2\",null,{\"className\":\"text-3xl md:text-5xl font-semibold leading-tight tracking-tight text-white\",\"children\":[\"Wi-Fi Power Optimization\",[\"$\",\"br\",null,{}],[\"$\",\"span\",null,{\"className\":\"text-cyan-400\",\"children\":\"Driven by Behavior.\"}]]}],[\"$\",\"p\",null,{\"className\":\"mx-auto mt-8 max-w-3xl text-lg leading-8 text-slate-400\",\"children\":\"Most access points run all radios at full power, around the clock — regardless of whether anyone is using them. 3rd-AI learns real household usage patterns and autonomously powers down idle radios during confirmed quiet windows. No schedules. No rules. No cloud.\"}]]}],[\"$\",\"$L5\",null,{\"delay\":0.1,\"children\":[\"$\",\"div\",null,{\"className\":\"grid gap-px overflow-hidden rounded-3xl border border-cyan-400/40 bg-cyan-400/20 md:grid-cols-2\",\"children\":[[\"$\",\"div\",\"01\",{\"className\":\"group bg-[#030508] p-10 transition-all duration-300 hover:bg-white/[0.04] hover:shadow-[inset_0_0_50px_-12px_rgba(34,211,238,0.4)]\",\"children\":[[\"$\",\"span\",null,{\"className\":\"mb-4 block text-sm font-bold tracking-widest text-cyan-400\",\"children\":\"01\"}],[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold text-cyan-400\",\"children\":\"Behavioral Traffic Analysis\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-base leading-7 text-slate-400\",\"children\":\"3rd-AI ingests per-band telemetry from the access point — every client, every minute. A KMeans clustering algorithm identifies IDLE vs ACTIVE traffic boundaries, self-calibrating thresholds per radio interface based on real household usage patterns.\"}],[\"$\",\"div\",null,{\"className\":\"mt-8 h-px w-16 bg-cyan-400\"}]]}],[\"$\",\"div\",\"02\",{\"className\":\"group bg-[#030508] p-10 transition-all duration-300 hover:bg-white/[0.04] hover:shadow-[inset_0_0_50px_-12px_rgba(34,211,238,0.4)]\",\"children\":[[\"$\",\"span\",null,{\"className\":\"mb-4 block text-sm font-bold tracking-widest text-cyan-400\",\"children\":\"02\"}],[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold text-cyan-400\",\"children\":\"Coverage Fidelity Gating\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-base leading-7 text-slate-400\",\"children\":\"Before acting, the platform validates telemetry coverage per hourly window. Hours below 65% fidelity are flagged as SPARSE SIGNAL — the agent abstains rather than misread a data gap as genuine inactivity. Conservative by design.\"}],[\"$\",\"div\",null,{\"className\":\"mt-8 h-px w-16 bg-cyan-400\"}]]}],[\"$\",\"div\",\"03\",{\"className\":\"group bg-[#030508] p-10 transition-all duration-300 hover:bg-white/[0.04] hover:shadow-[inset_0_0_50px_-12px_rgba(34,211,238,0.4)]\",\"children\":[[\"$\",\"span\",null,{\"className\":\"mb-4 block text-sm font-bold tracking-widest text-cyan-400\",\"children\":\"03\"}],[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold text-cyan-400\",\"children\":\"On-Device Inference\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-base leading-7 text-slate-400\",\"children\":\"The Ambient Intelligence Engine runs entirely inside the container — no cloud round-trip. It forecasts the next 24-hour optimization window using a structured behavioral context table, confirming a sleep schedule only when all radio interfaces agree.\"}],[\"$\",\"div\",null,{\"className\":\"mt-8 h-px w-16 bg-cyan-400\"}]]}],[\"$\",\"div\",\"04\",{\"className\":\"group bg-[#030508] p-10 transition-all duration-300 hover:bg-white/[0.04] hover:shadow-[inset_0_0_50px_-12px_rgba(34,211,238,0.4)]